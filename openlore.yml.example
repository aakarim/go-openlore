# OpenLore Configuration
# Place this file as openlore.yml in your project root,
# or specify a path with --config / -c.
#
# This file is for deployment config only (ports, paths, TLS).
# Auth policy (allow_keyless, unknown_identity, default_cwd)
# belongs in lore.json — see lore.json.example.

# Config file version. Used for migration between config formats.
version: "1"

# ── Server ────────────────────────────────────────────

# SSH server port. Agents connect here.
port: 2222

# HTTP front page port for human users (default 8080). Set to 0 to disable.
# http_port: 8080

# Prometheus metrics port. Set to 0 to disable.
metrics_port: 3000

# ── MCP (Model Context Protocol) ──────────────────────
#
# The MCP-over-HTTP endpoint lets MCP-aware clients (Claude Desktop,
# Cowork, etc.) browse your docs using the Streamable HTTP transport.
# It exposes the same filesystem as the SSH shell via two tools:
# `shell` and `list_commands`.
#
# It is mounted at `path` on the HTTP server (http_port above), so it
# reuses the same port and TLS — and any load balancer rule fronting it.
# Enabled by default. Set enabled: false to turn it off.
mcp:
  enabled: true
  path: /mcp

# ── JSON HTTP API ─────────────────────────────────────
#
# A plain JSON HTTP API, backed by the same MCP server, for clients that
# prefer simple REST calls over the MCP wire protocol. It exposes the
# same two tools:
#   POST {path}/shell     body {"command": "..."}
#   GET  {path}/commands
#
# Mounted at `path` on the HTTP server (http_port above). Enabled by
# default. Set enabled: false to turn it off.
api:
  enabled: true
  path: /api

# TLS certificate and key for the HTTP server (optional).
# Only applies to the HTTP front page, not SSH.
# tls_cert: ./cert.pem
# tls_key: ./key.pem

# Path to the SSH host key. Auto-generated on first run if missing.
# Uses ed25519 by default.
host_key_path: .ssh/openlore_ed25519

# ── Authentication ────────────────────────────────────

# Path to lore.json for identity-based access control.
# Maps SSH public keys to named "lore" specs that control which
# paths each identity can access. See lore.json.example for format.
# auth_file: lore.json

# ── SSH Certificates ──────────────────────────────────
#
# SSH certificates provide stronger auth than raw public keys.
# Instead of managing individual keys, a Certificate Authority (CA)
# signs short-lived certificates. Both sides can be configured:
#
#   1. User certificates  — clients prove identity via CA-signed certs
#   2. Host certificates  — server proves identity via CA-signed cert
#
# Quick setup with ssh-keygen:
#
#   # Create a CA key pair (guard the private key!)
#   ssh-keygen -t ed25519 -f my_ca -C "my-org CA"
#
#   # Sign a user's public key (valid 1 week, for principal "agent")
#   ssh-keygen -s my_ca -I agent@example -n agent -V +1w user_key.pub
#
#   # Sign the server's host key
#   ssh-keygen -s my_ca -I openlore.example.com -h -V +52w .ssh/openlore_ed25519.pub
#
#   # Client trusts all hosts signed by this CA (add to ~/.ssh/known_hosts)
#   @cert-authority *.example.com <contents of my_ca.pub>
#
# For automated certificate management, consider Smallstep step-ca:
#   https://smallstep.com/docs/step-ca/

# Path to a file containing trusted CA public keys for user certificate
# authentication. Users presenting certificates signed by any of these
# CAs will be accepted. Analogous to OpenSSH's TrustedUserCAKeys.
# Can be used alongside auth_file — both raw keys and certificates work.
# ca_keys_file: ./ca_user_key.pub

# Path to the server's host certificate, signed by a CA.
# When set, the server presents this certificate to clients, allowing
# them to verify the server's identity against the CA instead of
# relying on trust-on-first-use (TOFU) fingerprint prompts.
# Analogous to OpenSSH's HostCertificate directive.
# The certificate must correspond to the key at host_key_path.
# host_cert_file: .ssh/openlore_ed25519-cert.pub

# ── Passkeys / WebAuthn ───────────────────────────────
#
# Enable browser-based passkey authentication for human access
# to documentation via the HTTP server. When enabled, users can
# register passkeys from the SSH shell (`passkey` command) and
# then browse docs at /lore/ in a web browser.
#
# passkeys:
#   enabled: true
#   rp_id: docs.example.com          # WebAuthn Relying Party ID (your domain)
#   rp_name: "Acme Docs"             # Display name shown in browser passkey prompt
#   rp_origins:                       # Allowed origins for WebAuthn ceremonies
#     - "https://docs.example.com"
#   lore_path: /lore                  # HTTP path prefix for browsing docs
#   passkeys_file: ./config/passkeys.json  # Where credentials are stored
#   session_ttl: 24h                  # How long browser sessions last

# ── Bearer tokens (MCP + HTTP API) ────────────────────
#
# Enable bearer-token auth for the MCP + HTTP API. This is SERVER
# infrastructure — how this instance mints and verifies tokens — so it
# lives here, not in lore.json (which is access policy). When omitted,
# the MCP/HTTP endpoints serve anonymous callers (Phase 0). Posture
# (public vs token-required) still derives from lore.json's
# allow_keyless / unknown_identity.
#
# The ES256 signing key is generated on first boot under <data_dir>/auth/.
# Public keys are published at /.well-known/jwks.json. Passkey login mints
# tokens via the OAuth authorization-code + PKCE flow at /authorize →
# /oauth/token. Mint a debug/local token with:
#   openlore token mint --identity NAME --config ./openlore.yml
#
# tokens:
#   issuer: https://docs.example.com      # `iss` claim + JWKS base URL
#   audience: https://docs.example.com    # required `aud`; one per instance
#   access_ttl: 30m                       # access-token lifetime
#   refresh_ttl: 720h                     # refresh-token lifetime
#
# Workload Identity Federation (WIF): external IdPs whose JWTs are exchanged for
# OpenLore tokens at the token endpoint (grant_type=jwt-bearer). Each issuer's
# JWKS is discovered and its assertions are verified (issuer + our audience) and
# mapped to identities via `match` rules in lore.json. See
# docs/workload-identity-federation.md.
# oidc_issuers:
#   - issuer_url: https://token.actions.githubusercontent.com
#     jwks:
#       mode: discovery

# ── Content ───────────────────────────────────────────

# Only serve files matching these glob patterns.
# If empty, all files are served (except ignored ones).
files:
  allowed:
    - "*.md"
    - "*.txt"
    - "*.yml"
    - "*.yaml"
    - "*.json"
    - "*.rst"
    - "*.adoc"
  # Explicitly deny specific patterns (overrides allowed).
  # denied:
  #   - "secret-*.md"
  ignore:
    - ".git"
    - ".svn"
    - "node_modules"
    - "__pycache__"
    - ".env"
    - ".env.*"
    - "*.key"
    - "*.pem"
    - "*.p12"
    - ".DS_Store"

# Mount additional directories under named paths in the virtual filesystem.
# Each folder appears as a top-level directory in the shell.
# folders:
#   - name: api-docs
#     path: /var/docs/api
#   - name: runbooks
#     path: /var/docs/runbooks

# ── Skills ────────────────────────────────────────────

# Directory containing runtime skills (skills.json + markdown files).
# Embedded skills in assets/skills/ are always loaded.
# skills_dir: ./skills

# ── Storage Substrate Hooks ───────────────────────────
#
# Hooks are external shell commands that run on storage events.
# Three event kinds:
#   on_startup  — fires once when the server boots
#   pre_read    — fires before a virtual path is read (debounced per path)
#   post_write  — fires after bytes hit disk
#
# Each hook receives these env vars:
#   OPENLORE_DATA_DIR   server data root (from `data_dir` below)
#   OPENLORE_PATH       virtual path the event refers to
#   OPENLORE_AGENT      publishing agent ID (or empty)
#   OPENLORE_PARTITION  partition slug (or empty)
#   OPENLORE_EVENT      event kind
#   OPENLORE_BYTES      byte count (post_write only)
#
# Errors are non-fatal by default — set `fail_on_error: true` to flip.
#
# data_dir: /var/lib/openlore
# hooks:
#   on_startup:
#     - cmd: "/usr/local/bin/openlore-restore"
#       timeout: 30s
#   pre_read:
#     - cmd: "/usr/local/bin/openlore-pull"
#       debounce: 2s
#   post_write:
#     - cmd: "/usr/local/bin/openlore-version"
#       fail_on_error: true

# ── Display ───────────────────────────────────────────

# Message of the day shown when a client connects.
# Supports multiple lines with YAML block scalar.
motd: |
  Welcome to the docs server.
  Type 'tree -L 1 /' to see available documentation.
  Type 'skills' to see available agent commands.

# Alternatively, load MOTD from a file:
# motd_file: ./motd.txt
